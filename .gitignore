# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/

# Environments
.env
.env.*
.venv/
.venv*/
env/
venv/
.cache/
wandb/
mlruns/

# Data artifacts (local, NOT committed — download via src/data/download.py)
/data/

# Model weights and checkpoints (NOT committed — use models/README.md for download instructions)
/models/**/*.safetensors
/models/**/*.bin
/models/**/*.ckpt
/models/**/*.h5
/models/**/*.pkl
/artifacts/**/checkpoint/
/artifacts/**/*.safetensors
/artifacts/**/*.bin

# Allow README files inside models/ to be committed
!/models/README.md

# Result artifacts — JSON metrics and PNG charts ARE committed; raw CSVs are not
/results/*.csv

# Log artifacts
/logs/

# Binary / large files (safety net — never commit these regardless of path)
*.pkl
*.bin
*.ckpt
*.safetensors
*.h5

# IDEs
.vscode/
.idea/
.ipynb_checkpoints/

# Docker
*.dockerignore

# OS
.DS_Store
Thumbs.db

# HuggingFace Cache
/.hf_cache/

# Scratch CSVs and logs (runtime-generated, not for submission)
/scratch/*.csv
/scratch/*.jsonl
